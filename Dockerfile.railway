# Railway Dockerfile for Paperclip
# Uses dev server approach which builds on startup

FROM node:20-bookworm-slim

# Install pnpm
RUN corepack enable && corepack prepare pnpm@9.15.4 --activate

# Create non-root user
RUN addgroup -g 1001 -S paperclip && \
    adduser -S -D -H -u 1001 -s /sbin/nologin -G paperclip paperclip

WORKDIR /app

# Copy package files first for better caching
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml .npmrc ./
COPY cli/package.json cli/
COPY server/package.json server/
COPY ui/package.json ui/
COPY packages/shared/package.json packages/shared/
COPY packages/db/package.json packages/db/
COPY packages/adapter-utils/package.json packages/adapter-utils/
COPY packages/adapters/claude-local/package.json packages/adapters/claude-local/
COPY packages/adapters/codex-local/package.json packages/adapters/codex-local/
COPY packages/adapters/opencode-local/package.json packages/adapters/opencode-local/
COPY packages/adapters/cursor-local/package.json packages/adapters/cursor-local/
COPY packages/adapters/openclaw/package.json packages/adapters/openclaw/
COPY packages/adapters/process/package.json packages/adapters/process/
COPY packages/adapters/http/package.json packages/adapters/http/
COPY skills ./skills

# Install dependencies
RUN pnpm install --frozen-lockfile

# Copy source code
COPY . .

# Build the project
RUN pnpm build || true

# Create data directory
RUN mkdir -p /paperclip/instances/default && \
    chown -R paperclip:paperclip /paperclip /app

USER paperclip

# Environment
ENV NODE_ENV=production \
  HOME=/paperclip \
  HOST=0.0.0.0 \
  PORT=3100 \
  SERVE_UI=true \
  PAPERCLIP_HOME=/paperclip \
  PAPERCLIP_INSTANCE_ID=default \
  PAPERCLIP_DEPLOYMENT_MODE=authenticated \
  PAPERCLIP_DEPLOYMENT_EXPOSURE=public

EXPOSE 3100

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retry=3 \
    CMD wget --no-verbose --tries=1 --spider http://localhost:3100/api/health || exit 1

# Start the server
CMD ["npx", "tsx", "server/src/index.ts"]